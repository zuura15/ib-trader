# IB Gateway connection
IB_HOST=127.0.0.1
IB_PORT=4001
IB_CLIENT_ID=1
IB_ACCOUNT_ID=U1234567

# Paper trading (optional — uses these when --paper flag is passed)
IB_PORT_PAPER=4002
IB_ACCOUNT_ID_PAPER=DU1234567
IB_MARKET_DATA_TYPE_PAPER=3

# Alpaca (optional — for multi-broker support)
# ALPACA_API_KEY=your_api_key
# ALPACA_SECRET_KEY=your_secret_key

# API server auth (optional — if set, all API requests require Bearer token)
# API_SECRET_KEY=your_random_secret_here
